NODE_ENV=production
HOST=0.0.0.0
PORT=10000

# Strapi secrets
APP_KEYS=replace-with-4-comma-separated-random-values
API_TOKEN_SALT=replace-with-random-value
ADMIN_JWT_SECRET=replace-with-random-value
ADMIN_JWT_EXPIRES_IN=100y
TRANSFER_TOKEN_SALT=replace-with-random-value
JWT_SECRET=replace-with-random-value
JWT_EXPIRES_IN=100y
ENCRYPTION_KEY=replace-with-random-value

# PostgreSQL for Render
DATABASE_CLIENT=postgres
DATABASE_URL=
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_NAME=
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_SCHEMA=public
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
