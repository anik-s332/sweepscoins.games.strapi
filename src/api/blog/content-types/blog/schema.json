{
  "kind": "collectionType",
  "collectionName": "blogs",
  "info": {
    "singularName": "blog",
    "pluralName": "blogs",
    "displayName": "Blog",
    "description": "Structured blog content with dynamic sections, metadata, and sidebar relations"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "content": {
      "type": "dynamiczone",
      "components": [
        "blog.heading",
        "blog.paragraph",
        "blog.list",
        "blog.image"
      ]
    },
    "tableOfContents": {
      "type": "component",
      "repeatable": true,
      "component": "blog.table-of-contents-item"
    },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::author.author",
      "inversedBy": "blogs"
    },
    "publishDate": {
      "type": "datetime",
      "required": true
    },
    "viewsCount": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "inversedBy": "blogs"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "blogs"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    },
    "popularArticles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::blog.blog"
    },
    "relatedBlogs": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::blog.blog"
    }
  }
}
